# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Prefer new publishable/secret keys (sb_publishable_... / sb_secret_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# JWT verification (for @supabase/server)
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3001
NEXT_PUBLIC_SITE_NAME="Nexvor Intl"

# Optional override for the full company catalog PDF download on /catalog
# Default: {SUPABASE_URL}/storage/v1/object/public/pdf-catalogs/company/full-catalog.pdf
# Upload via Admin → Catalog PDF, or paste a public Supabase Storage URL here
# NEXT_PUBLIC_CATALOG_PDF_URL=https://your-project.supabase.co/storage/v1/object/public/pdf-catalogs/company/full-catalog.pdf

# AI category detection for PDF import (image + product name)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional model override (default: gpt-4o-mini)
# OPENAI_CATEGORY_MODEL=gpt-4o-mini
